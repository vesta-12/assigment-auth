@startuml
actor User
participant "Web Server" as Server
database "Database" as DB

User -> Server: Enter username and password\nPOST /login
Server -> DB: Find user by username
DB --> Server: Return user data

alt Credentials are valid
    Server -> Server: Validate password
    Server --> User: 200 OK\nReturn token/session
else Credentials are invalid
    Server -> Server: Validate password
    Server --> User: 401 Unauthorized\nReturn error message
end

@enduml